package(default_visibility = ["//visibility:public"])

cc_import(
    name = "gpiod_arm64",
    hdrs = ["include/gpiod.h"],
    shared_library = "lib/libgpiod.so",
    includes = ["include"],
    system_provided = False,
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:aarch64",
