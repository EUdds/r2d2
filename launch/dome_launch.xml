<launch>
  <!-- Start joystick driver (Xbox controller) -->
  <node pkg="joy" exec="joy_node" name="joy_node" output="screen" />

  <!-- Translate joystick axes/buttons to dome speed commands -->
  <node pkg="joystick_ctrl" exec="joystick_ctrl" name="joystick_ctrl" output="screen">
    <param name="dome_speed_topic" value="dome/speed" />
    <param name="dome_axis" value="0" />
    <param name="dome_invert" value="false" />
    <param name="dome_max_speed_dps" value="90.0" />
    <param name="deadzone" value="0.05" />
    <param name="use_sim_time" value="false" />
  </node>

  <!-- Drive the dome motor using velocity commands -->
  <node pkg="dome_ctlr" exec="dome_ctlr_node" name="dome_ctlr" output="screen">
    <param name="speed_topic" value="dome/speed" />
    <param name="use_seek_topic" value="false" />
    <param name="enable_on_start" value="true" />
    <!-- GPIO/motor params can be overridden as needed -->
    <param name="chip_name" value="gpiochip4" />
    <param name="step_pin" value="3" />
    <param name="dir_pin" value="2" />
    <param name="enable_pin" value="22" />
    <param name="enable_active_high" value="false" />
    <param name="ms1_present" value="true" />
    <param name="ms1_pin" value="4" />
    <param name="ms2_present" value="true" />
    <param name="ms2_pin" value="17" />
    <param name="ms1_high" value="false" />
    <param name="ms2_high" value="false" />
    <param name="motor_full_steps" value="200.0" />
    <param name="gear_ratio" value="8.2666666667" />
    <param name="pulse_width_us" value="5" />
    <param name="min_step_delay_us" value="500" />
    <param name="current_angle_deg" value="0.0" />
  </node>
</launch>
